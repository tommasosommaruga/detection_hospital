# PathAssist production settings (copy to .env and customize)

PATHASSIST_ENV=production
PATHASSIST_HOST=0.0.0.0
PATHASSIST_PORT=8765
PATHASSIST_LOG_LEVEL=INFO

# Required in production — clients send: X-API-Key: <value>
PATHASSIST_API_KEY=

PATHASSIST_CONFIG=config/production.yaml
# Optional: override default checkpoint (per-organ models live under models/<organ>/ensemble.pt)
# PATHASSIST_CHECKPOINT=models/gastrointestinal/ensemble.pt
PATHASSIST_RUNS_DIR=runs
PATHASSIST_RESULTS_DIR=outputs/demo_results
PATHASSIST_UPLOAD_DIR=outputs/demo_uploads

PATHASSIST_REQUIRE_CHECKPOINT=true
PATHASSIST_MAX_UPLOAD_MB=50
PATHASSIST_CORS_ORIGINS=http://localhost:8765

# Optional: local benchmark tiles (demo Dataset Hub → "Use local folder")
# data/benchmarks/<organ>/benign/*.png
# data/benchmarks/<organ>/malignant/*.png
